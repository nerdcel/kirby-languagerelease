{
  "name": "nerdcel/kirby-languagerelease",
  "description": "A Kirby CMS plugin to control the release status of language variants with frontend access control",
  "version": "1.0.1",
  "type": "kirby-plugin",
  "license": "MIT",
  "keywords": [
    "kirby",
    "kirby-cms",
    "kirby-plugin",
    "multilingual",
    "language",
    "release",
    "publish",
    "translation"
  ],
  "authors": [
    {
      "name": "Nerdcel",
      "email": "info@nerdcel.de"
    }
  ],
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  },
  "require": {
    "php": "^8.2",
    "getkirby/cms": "^5.0",
    "getkirby/composer-installer": "^1.2.1"
  },
  "autoload": {
    "files": [
      "index.php"
    ]
  },
  "extra": {
    "installer-name": "kirby-languagerelease",
    "kirby-cms-path": false
  }
}

