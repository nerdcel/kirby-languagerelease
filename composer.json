{
  "name": "nerdcel/kirby-languagerelease",
  "description": "A Kirby CMS plugin to control the release status of language variants with frontend access control",
  "type": "kirby-plugin",
  "license": "MIT",
  "keywords": [
    "kirby",
    "kirby-cms",
    "kirby-plugin",
    "multilingual",
    "language",
    "release",
    "publish",
    "translation"
  ],
  "authors": [
    {
      "name": "Nerdcel",
      "email": "info@nerdcel.de"
    }
  ],
  "homepage": "https://github.com/nerdcel/kirby-languagerelease",
  "support": {
    "issues": "https://github.com/nerdcel/kirby-languagerelease/issues",
    "source": "https://github.com/nerdcel/kirby-languagerelease"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  },
  "require": {
    "php": "^8.2",
    "getkirby/cms": "^5.0",
    "getkirby/composer-installer": "^1.2.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit",
    "release:patch": "./release.sh patch",
    "release:minor": "./release.sh minor",
    "release:major": "./release.sh major"
  },
  "autoload": {
    "files": [
      "index.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Nerdcel\\LanguageRelease\\Tests\\": "tests/"
    }
  },
  "extra": {
    "installer-name": "kirby-languagerelease",
    "kirby-cms-path": false
  }
}
