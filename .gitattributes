# Auto-detect text files and normalise line endings
* text=auto eol=lf

*.php text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Archives
*.zip binary
*.tar binary
*.gz binary

# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.svg binary
*.ico binary

# ──────────────────────────────────────────────
# Exclude from Composer/Packagist dist archives
# (also used by `git archive` and GitHub ZIP downloads)
# ──────────────────────────────────────────────

# Git / CI / Release tooling
.git/               export-ignore
.gitattributes       export-ignore
.gitignore           export-ignore
.github/             export-ignore
release.sh           export-ignore

# IDE / OS
.idea/               export-ignore
.vscode/             export-ignore
.DS_Store            export-ignore

# Testing
tests/               export-ignore
phpunit.xml          export-ignore
.phpunit.cache/      export-ignore

# Frontend source (compiled index.js is sufficient)
src/                 export-ignore
node_modules/        export-ignore
package.json         export-ignore

# Documentation (README + LICENSE are enough)
CONTRIBUTING.md      export-ignore
CONFIGURATION.md     export-ignore
FRONTEND-ACCESS.md   export-ignore
INSTALLATION.md      export-ignore
config.example.php   export-ignore
screen.png           export-ignore
